{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ESNext",
		"noEmit": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"vite.config.ts",
		"svelte.config.js"
	]
}
